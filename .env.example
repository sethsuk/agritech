# Copy this file to .env.local and fill in the values from your Supabase project.
# Supabase Dashboard → Project Settings → API & Database

# Direct connection (used by Prisma migrations).
# Supabase Dashboard → Project Settings → Database → Connection string → "URI" tab → "Direct connection".
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Pooled connection (used by the running app at runtime).
# Supabase Dashboard → Project Settings → Database → Connection string → "URI" tab → "Transaction pooler".
# Add ?pgbouncer=true&connection_limit=1 at the end for serverless safety.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Public Supabase URL and anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Server-only service role key (NEVER expose to the browser).
# Used by /api/uploads to write to the inspection-photos bucket.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
